# Supabase Configuration Template
# Copy this file to .env.local and fill in your actual credentials
# .env.local is in .gitignore and will NOT be committed

# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Get this from Supabase Settings > API > Project API keys > Secret
# Only use locally - NEVER commit the real key
SUPABASE_SECRET_KEY=your-secret-key-here
